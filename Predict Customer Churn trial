    "\"\"\"\n",
    "Kaggle Playground 2026 — Customer Churn  v6\n",
    "New ideas to break past 0.9161:\n",
    "\n",
    "1. SAMPLE WEIGHTS via distribution matching\n",
    "   - Train a classifier: \"is this row from original or synthetic data?\"\n",
    "   - Rows that look more like original data → higher sample weight\n",
    "   - This tells XGB/LGB/CAT to trust cleaner rows more\n",
    "\n",
    "2. FREQUENCY ENCODING\n",
    "   - How often does each category value appear?\n",
    "   - Rare categories often have different churn behaviour\n",
    "   - Complements target encoding\n",
    "\n",
    "3. LEAVE-ONE-OUT TARGET ENCODING (inside fold)\n",
    "   - Smoother and less leaky than standard target encoding\n",
    "\n",
    "4. NEURAL NETWORK (TabNet-style MLP)\n",
    "   - Completely different function class from all tree models\n",
    "   - Adds real diversity to the stack\n",
    "\n",
    "5. NEIGHBOUR FEATURES\n",
    "   - For each row, find its K nearest neighbours in the training set\n",
    "   - Add their mean churn rate as a feature\n",
    "   - Captures local structure trees miss\n",
    "\"\"\"\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import warnings\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "import os\n",
    "\n",
    "from scipy.stats import rankdata\n",
    "from sklearn.model_selection import StratifiedKFold\n",
    "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
    "from sklearn.metrics import roc_auc_score\n",
    "from sklearn.ensemble import RandomForestClassifier, ExtraTreesClassifier\n",
    "from sklearn.linear_model import LogisticRegression, Ridge\n",
    "from sklearn.neighbors import NearestNeighbors\n",
    "from sklearn.neural_network import MLPClassifier\n",
    "from category_encoders import LeaveOneOutEncoder\n",
    "\n",
    "import xgboost as xgb\n",
    "import lightgbm as lgb\n",
    "from catboost import CatBoostClassifier\n",
    "\n",
    "SEED     = 42\n",
    "N_SPLITS = 5\n",
    "skf      = StratifiedKFold(n_splits=N_SPLITS, shuffle=True, random_state=SEED)\n",
    "\n",
    "\n",
    "\n",
    "train = pd.read_csv(\"/kaggle/input/competitions/playground-series-s6e3/train.csv\")\n",
    "test  = pd.read_csv(\"/kaggle/input/competitions/playground-series-s6e3/test.csv\")\n",
    "TARGET = \"Churn\"\n",
    "ID_COL = \"id\"\n",
    "\n",
    "train[TARGET] = train[TARGET].map({\"Yes\": 1, \"No\": 0, 1: 1, 0: 0, \"1\": 1, \"0\": 0}).astype(int)\n",
    "print(f\"Train : {train.shape}  |  Test : {test.shape}\")\n",
    "print(f\"Churn rate : {train[TARGET].mean():.3f}\")\n",
    "\n",
    "churn_counts     = train[TARGET].value_counts().sort_index()\n",
    "imbalance_ratio  = churn_counts[0] / churn_counts[1]\n",
    "USE_CLASS_WEIGHT = imbalance_ratio > 3\n",
    "scale_pos        = int(imbalance_ratio) if USE_CLASS_WEIGHT else 1\n",
    "\n",
    "num_cols = [c for c in train.select_dtypes(include=[np.number]).columns if c not in [ID_COL, TARGET]]\n",
    "cat_cols = [c for c in train.select_dtypes(include=\"object\").columns  if c not in [ID_COL, TARGET]]\n",
    "\n",
    "\n",
    "\n",
    "ORIG_PATHS = [\n",
    "    \"/kaggle/input/telco-customer-churn/WA_Fn-UseC_-Telco-Customer-Churn.csv\",\n",
    "    \"WA_Fn-UseC_-Telco-Customer-Churn.csv\",\n",
    "]\n",
    "orig_path = next((p for p in ORIG_PATHS if os.path.exists(p)), None)\n",
    "\n",
    "sample_weights = np.ones(len(train))   # default: all rows equal weight\n",
    "orig_available = False\n",
    "\n",
    "if orig_path:\n",
    "    orig = pd.read_csv(orig_path)\n",
    "    orig[TARGET] = orig[TARGET].map({\"Yes\": 1, \"No\": 0}).astype(int)\n",
    "    orig = orig.drop(columns=[\"customerID\"], errors=\"ignore\")\n",
    "    shared_cols = [c for c in orig.columns if c in train.columns and c != ID_COL]\n",
    "    orig = orig[shared_cols]\n",
    "\n",
    "    # ── Label encode both for the classifier ─────────────────────────\n",
    "    orig_enc  = orig.copy()\n",
    "    train_enc = train[shared_cols].copy()\n",
    "    test_enc  = test[[c for c in shared_cols if c != TARGET]].copy()\n",
    "\n",
    "    for col in orig_enc.select_dtypes(include=\"object\").columns:\n",
    "        le = LabelEncoder()\n",
    "        combined = pd.concat([train_enc[col], orig_enc[col], test_enc[col]\n",
    "                               if col in test_enc.columns else pd.Series(dtype=str)],\n",
    "                              axis=0).astype(str)\n",
    "        le.fit(combined)\n",
    "        orig_enc[col]  = le.transform(orig_enc[col].astype(str))\n",
    "        train_enc[col] = le.transform(train_enc[col].astype(str))\n",
    "        if col in test_enc.columns:\n",
    "            test_enc[col] = le.transform(test_enc[col].astype(str))\n",
    "\n",
    "    if \"TotalCharges\" in orig_enc.columns:\n",
    "        orig_enc[\"TotalCharges\"]  = pd.to_numeric(orig_enc[\"TotalCharges\"],  errors=\"coerce\").fillna(0)\n",
    "        train_enc[\"TotalCharges\"] = pd.to_numeric(train_enc[\"TotalCharges\"], errors=\"coerce\").fillna(0)\n",
    "\n",
    "    feat_sw = [c for c in orig_enc.columns if c != TARGET]\n",
    "\n",
    "    # Label: 1 = original, 0 = synthetic\n",
    "    X_sw = pd.concat([train_enc[feat_sw], orig_enc[feat_sw]], ignore_index=True)\n",
    "    y_sw = np.array([0]*len(train_enc) + [1]*len(orig_enc))\n",
    "\n",
    "    clf_sw = lgb.LGBMClassifier(n_estimators=200, learning_rate=0.05,\n",
    "                                  random_state=SEED, verbose=-1, n_jobs=-1)\n",
    "    clf_sw.fit(X_sw, y_sw)\n",
    "\n",
    "    # P(original | row) for each train row → use as sample weight\n",
    "    p_original    = clf_sw.predict_proba(train_enc[feat_sw])[:, 1]\n",
    "    sample_weights = 1.0 + 2.0 * p_original   # range: [1, 3]\n",
    "    # Rows that look like original data weighted up to 3×\n",
    "\n",
    "    print(f\"Original dataset loaded: {len(orig):,} rows\")\n",
    "    print(f\"Sample weight stats — min:{sample_weights.min():.2f}  \"\n",
    "          f\"mean:{sample_weights.mean():.2f}  max:{sample_weights.max():.2f}\")\n",
    "\n",
    "    # Merge original into train for training\n",
    "    orig[ID_COL] = -1\n",
    "    train = pd.concat([train, orig], ignore_index=True)\n",
    "    # Extend sample weights: original rows get weight 3.0 (they ARE original)\n",
    "    sample_weights = np.concatenate([sample_weights,\n",
    "                                      np.full(len(orig), 3.0)])\n",
    "    orig_available = True\n",
    "    print(f\"Merged train size: {len(train):,}\")\n",
    "else:\n",
    "    print(\"Original dataset not found — using uniform weights\")\n",
    "    print(\"Add it on Kaggle via Data panel → search 'blastchar telco'\")\n",
    "\n",
    "\n",
    "# SECTION 4 │ FEATURE ENGINEERING\n",
    "\n",
    "\n",
    "\n",
    "def engineer_features(df, ref_df=None):\n",
    "    df  = df.copy()\n",
    "    ref = ref_df if ref_df is not None else df\n",
    "\n",
    "    if \"TotalCharges\" in df.columns:\n",
    "        df[\"TotalCharges\"] = pd.to_numeric(df[\"TotalCharges\"], errors=\"coerce\").fillna(0)\n",
    "\n",
    "    if \"tenure\" in df.columns:\n",
    "        df[\"tenure_group\"]  = pd.cut(df[\"tenure\"], bins=[0,6,12,24,48,60,np.inf],\n",
    "                                      labels=[1,2,3,4,5,6]).astype(float)\n",
    "        df[\"is_new\"]        = (df[\"tenure\"] <= 6).astype(int)\n",
    "        df[\"is_mid\"]        = ((df[\"tenure\"] > 6) & (df[\"tenure\"] <= 24)).astype(int)\n",
    "        df[\"is_long\"]       = (df[\"tenure\"] >= 48).astype(int)\n",
    "        df[\"log_tenure\"]    = np.log1p(df[\"tenure\"])\n",
    "        df[\"tenure_inv\"]    = 1 / (df[\"tenure\"] + 1)\n",
    "        df[\"tenure_sq\"]     = df[\"tenure\"] ** 2\n",
    "\n",
    "    if \"MonthlyCharges\" in df.columns:\n",
    "        mc_mean = ref[\"MonthlyCharges\"].mean()\n",
    "        mc_std  = ref[\"MonthlyCharges\"].std()\n",
    "        df[\"log_monthly\"]     = np.log1p(df[\"MonthlyCharges\"])\n",
    "        df[\"monthly_zscore\"]  = (df[\"MonthlyCharges\"] - mc_mean) / (mc_std + 1e-6)\n",
    "        df[\"monthly_vs_mean\"] = df[\"MonthlyCharges\"] / (mc_mean + 1e-6)\n",
    "        df[\"is_high_value\"]   = (df[\"MonthlyCharges\"] > ref[\"MonthlyCharges\"].quantile(0.75)).astype(int)\n",
    "        df[\"is_low_value\"]    = (df[\"MonthlyCharges\"] < ref[\"MonthlyCharges\"].quantile(0.25)).astype(int)\n",
    "\n",
    "    if \"MonthlyCharges\" in df.columns and \"tenure\" in df.columns:\n",
    "        df[\"charges_per_tenure\"] = df[\"MonthlyCharges\"] / (df[\"tenure\"] + 1)\n",
    "        df[\"tenure_x_monthly\"]   = df[\"tenure\"] * df[\"MonthlyCharges\"]\n",
    "        df[\"log_t_x_log_m\"]      = np.log1p(df[\"tenure\"]) * np.log1p(df[\"MonthlyCharges\"])\n",
    "\n",
    "    if all(c in df.columns for c in [\"TotalCharges\", \"MonthlyCharges\", \"tenure\"]):\n",
    "        df[\"expected_total\"]       = df[\"MonthlyCharges\"] * df[\"tenure\"]\n",
    "        df[\"charge_deviation\"]     = df[\"TotalCharges\"] - df[\"expected_total\"]\n",
    "        df[\"charge_deviation_pct\"] = df[\"charge_deviation\"] / (df[\"expected_total\"] + 1)\n",
    "        df[\"log_total\"]            = np.log1p(df[\"TotalCharges\"])\n",
    "        df[\"total_to_monthly\"]     = df[\"TotalCharges\"] / (df[\"MonthlyCharges\"] + 1)\n",
    "        df[\"total_to_expected\"]    = df[\"TotalCharges\"] / (df[\"expected_total\"] + 1)\n",
    "\n",
    "    svc = [c for c in [\"PhoneService\",\"MultipleLines\",\"InternetService\",\n",
    "                        \"OnlineSecurity\",\"OnlineBackup\",\"DeviceProtection\",\n",
    "                        \"TechSupport\",\"StreamingTV\",\"StreamingMovies\"] if c in df.columns]\n",
    "    if svc:\n",
    "        df[\"num_services\"]    = (df[svc] == \"Yes\").sum(axis=1)\n",
    "        df[\"has_no_services\"] = (df[\"num_services\"] == 0).astype(int)\n",
    "        df[\"has_streaming\"]   = (\n",
    "            (df.get(\"StreamingTV\",     pd.Series(\"No\", index=df.index)) == \"Yes\") |\n",
    "            (df.get(\"StreamingMovies\", pd.Series(\"No\", index=df.index)) == \"Yes\")\n",
    "        ).astype(int)\n",
    "        if \"MonthlyCharges\" in df.columns:\n",
    "            df[\"charge_per_service\"] = df[\"MonthlyCharges\"] / (df[\"num_services\"] + 1)\n",
    "\n",
    "    if \"Contract\" in df.columns:\n",
    "        df[\"contract_risk\"]       = df[\"Contract\"].map(\n",
    "            {\"Month-to-month\": 2, \"One year\": 1, \"Two year\": 0}).fillna(1)\n",
    "        df[\"is_monthly_contract\"] = (df[\"Contract\"] == \"Month-to-month\").astype(int)\n",
    "\n",
    "    if \"PaymentMethod\" in df.columns:\n",
    "        df[\"auto_pay\"]      = df[\"PaymentMethod\"].str.contains(\"automatic\", case=False, na=False).astype(int)\n",
    "        df[\"is_electronic\"] = df[\"PaymentMethod\"].str.contains(\"electronic\", case=False, na=False).astype(int)\n",
    "\n",
    "    risk = pd.Series(0.0, index=df.index)\n",
    "    if \"contract_risk\"  in df.columns: risk += df[\"contract_risk\"]  * 0.35\n",
    "    if \"auto_pay\"       in df.columns: risk += (1 - df[\"auto_pay\"]) * 0.20\n",
    "    if \"is_new\"         in df.columns: risk += df[\"is_new\"]         * 0.20\n",
    "    if \"num_services\"   in df.columns: risk += (1 / (df[\"num_services\"] + 1)) * 0.15\n",
    "    if \"is_high_value\"  in df.columns: risk += df[\"is_high_value\"]  * 0.10\n",
    "    df[\"composite_risk\"] = risk\n",
    "\n",
    "    if \"contract_risk\" in df.columns:\n",
    "        if \"num_services\"       in df.columns: df[\"risk_x_services\"] = df[\"contract_risk\"] * df[\"num_services\"]\n",
    "        if \"charges_per_tenure\" in df.columns: df[\"risk_x_charge\"]   = df[\"contract_risk\"] * df[\"charges_per_tenure\"]\n",
    "        if \"tenure_inv\"         in df.columns: df[\"risk_x_new\"]      = df[\"contract_risk\"] * df[\"tenure_inv\"]\n",
    "    if \"composite_risk\" in df.columns and \"MonthlyCharges\" in df.columns:\n",
    "        df[\"risk_x_monthly\"] = df[\"composite_risk\"] * df[\"MonthlyCharges\"]\n",
    "    if \"SeniorCitizen\" in df.columns:\n",
    "        if \"MonthlyCharges\" in df.columns: df[\"senior_x_monthly\"] = df[\"SeniorCitizen\"] * df[\"MonthlyCharges\"]\n",
    "        if \"contract_risk\"  in df.columns: df[\"senior_x_risk\"]    = df[\"SeniorCitizen\"] * df[\"contract_risk\"]\n",
    "\n",
    "    return df\n",
    "\n",
    "train_raw = train.copy()\n",
    "train = engineer_features(train, ref_df=train_raw)\n",
    "test  = engineer_features(test,  ref_df=train_raw)\n",
    "print(f\"Train shape after engineering : {train.shape}\")\n",
    "\n",
    "all_cat = [c for c in train.select_dtypes(include=\"object\").columns if c not in [ID_COL, TARGET]]\n",
    "\n",
    "\n",
    "# SECTION 5 │ FREQUENCY ENCODING  (new — added globally, no leakage)\n",
    "# How often each category appears — rare values have different behaviour\n",
    "\n",
    "\n",
    "\n",
    "freq_cols = []\n",
    "for col in all_cat:\n",
    "    freq_map         = train[col].value_counts(normalize=True).to_dict()\n",
    "    train[f\"{col}_freq\"] = train[col].map(freq_map).fillna(0)\n",
    "    test[f\"{col}_freq\"]  = test[col].map(freq_map).fillna(0)\n",
    "    freq_cols.append(f\"{col}_freq\")\n",
    "\n",
    "print(f\"Added {len(freq_cols)} frequency features: {freq_cols}\")\n",
    "\n",
    "\n",
    "# SECTION 6 │ LABEL ENCODING BASE\n",
    "\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"SECTION 6 │ Label Encoding\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "le_dict = {}\n",
    "for col in all_cat:\n",
    "    le = LabelEncoder()\n",
    "    combined = pd.concat([train[col], test[col]], axis=0).astype(str)\n",
    "    le.fit(combined)\n",
    "    train[col] = le.transform(train[col].astype(str))\n",
    "    test[col]  = le.transform(test[col].astype(str))\n",
    "    le_dict[col] = le\n",
    "\n",
    "train.fillna(train.median(numeric_only=True), inplace=True)\n",
    "test.fillna(train.median(numeric_only=True),  inplace=True)\n",
    "\n",
    "feat_cols = [c for c in train.columns if c not in [ID_COL, TARGET]]\n",
    "X_le      = train[feat_cols].reset_index(drop=True)\n",
    "X_test_le = test[feat_cols].reset_index(drop=True)\n",
    "y         = train[TARGET].reset_index(drop=True).astype(int)\n",
    "sw        = pd.Series(sample_weights).reset_index(drop=True)\n",
    "\n",
    "print(f\"Features : {X_le.shape[1]}\")\n",
    "\n",
    "\n",
    "# SECTION 7 │ NEIGHBOUR FEATURES\n",
    "# Mean churn rate of K nearest neighbours — captures local structure\n",
    "\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"SECTION 7 │ Neighbour Features (KNN mean target)\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "# Scale for distance computation\n",
    "scaler_nn = StandardScaler()\n",
    "X_le_sc   = scaler_nn.fit_transform(X_le)\n",
    "X_test_sc = scaler_nn.transform(X_test_le)\n",
    "\n",
    "# Fit on full train — for test neighbour features no leakage issue\n",
    "nn = NearestNeighbors(n_neighbors=51, metric=\"euclidean\", n_jobs=-1)\n",
    "nn.fit(X_le_sc)\n",
    "\n",
    "# For train: use leave-one-out (exclude self) → no leakage\n",
    "_, train_nn_idx = nn.kneighbors(X_le_sc)\n",
    "train_nn_churn  = np.array([y.iloc[idxs[1:]].mean() for idxs in train_nn_idx])\n",
    "\n",
    "# For test: all 51 neighbours are fine\n",
    "_, test_nn_idx = nn.kneighbors(X_test_sc)\n",
    "test_nn_churn  = np.array([y.iloc[idxs].mean() for idxs in test_nn_idx])\n",
    "\n",
    "X_le[\"nn_mean_churn\"]      = train_nn_churn\n",
    "X_test_le[\"nn_mean_churn\"] = test_nn_churn\n",
    "print(f\"Neighbour feature added — train mean: {train_nn_churn.mean():.3f}\")\n",
    "\n",
    "# SECTION 8 │ 5-FOLD CV TRAINING\n",
    "# XGB/LGB/CAT → LOO target encoded + sample weights\n",
    "# RF/ET       → label encoded + sample weights\n",
    "# MLP         → scaled features, different function class entirely\n",
    "\n",
    "\n",
    "\n",
    "models   = [\"XGB\", \"LGB\", \"CAT\", \"RF\", \"ET\", \"MLP\"]\n",
    "oof      = {m: np.zeros(len(X_le))      for m in models}\n",
    "test_p   = {m: np.zeros(len(X_test_le)) for m in models}\n",
    "fold_auc = {m: []                        for m in models}\n",
    "\n",
    "for fold, (tr_idx, val_idx) in enumerate(skf.split(X_le, y), 1):\n",
    "    print(f\"\\n  ── Fold {fold}/{N_SPLITS} ──\")\n",
    "\n",
    "    X_tr_le,  X_val_le  = X_le.iloc[tr_idx].copy(),  X_le.iloc[val_idx].copy()\n",
    "    y_tr,     y_val     = y.iloc[tr_idx],              y.iloc[val_idx]\n",
    "    sw_tr               = sw.iloc[tr_idx].values\n",
    "\n",
    "    # ── In-fold LOO target encoding for boosting models ──────────────\n",
    "    X_tr_te  = train[feat_cols].iloc[tr_idx].copy()\n",
    "    X_val_te = train[feat_cols].iloc[val_idx].copy()\n",
    "    X_test_te = test[feat_cols].copy()\n",
    "\n",
    "    # Add nn feature\n",
    "    X_tr_te[\"nn_mean_churn\"]  = train_nn_churn[tr_idx]\n",
    "    X_val_te[\"nn_mean_churn\"] = train_nn_churn[val_idx]\n",
    "    X_test_te[\"nn_mean_churn\"] = test_nn_churn\n",
    "\n",
    "    loo = LeaveOneOutEncoder(cols=all_cat, sigma=0.05, random_state=SEED)\n",
    "    X_tr_te[all_cat]  = loo.fit_transform(X_tr_te[all_cat], y_tr)\n",
    "    X_val_te[all_cat] = loo.transform(X_val_te[all_cat])\n",
    "    X_test_te[all_cat] = loo.transform(X_test_te[all_cat])\n",
    "\n",
    "    X_tr_te.fillna(X_tr_te.median(),   inplace=True)\n",
    "    X_val_te.fillna(X_tr_te.median(),  inplace=True)\n",
    "    X_test_te.fillna(X_tr_te.median(), inplace=True)\n",
    "\n",
    "    # ── XGBoost ──────────────────────────────────────────────────────\n",
    "    m = xgb.XGBClassifier(\n",
    "        n_estimators=1000, learning_rate=0.05, max_depth=6,\n",
    "        subsample=0.8, colsample_bytree=0.8, min_child_weight=3,\n",
    "        reg_alpha=0.1, reg_lambda=1.0, scale_pos_weight=scale_pos,\n",
    "        eval_metric=\"auc\", early_stopping_rounds=50,\n",
    "        random_state=SEED, n_jobs=-1, verbosity=0\n",
    "    )\n",
    "    m.fit(X_tr_te, y_tr, eval_set=[(X_val_te, y_val)],\n",
    "          sample_weight=sw_tr, verbose=False)\n",
    "    oof[\"XGB\"][val_idx] = m.predict_proba(X_val_te)[:, 1]\n",
    "    test_p[\"XGB\"]      += m.predict_proba(X_test_te)[:, 1] / N_SPLITS\n",
    "    s = roc_auc_score(y_val, oof[\"XGB\"][val_idx])\n",
    "    fold_auc[\"XGB\"].append(s); print(f\"     XGB  AUC: {s:.4f}\")\n",
    "\n",
    "    # ── LightGBM ─────────────────────────────────────────────────────\n",
    "    m = lgb.LGBMClassifier(\n",
    "        n_estimators=1000, learning_rate=0.05, num_leaves=63,\n",
    "        subsample=0.8, colsample_bytree=0.8, min_child_samples=20,\n",
    "        reg_alpha=0.1, reg_lambda=1.0,\n",
    "        class_weight=\"balanced\" if USE_CLASS_WEIGHT else None,\n",
    "        random_state=SEED, n_jobs=-1, verbose=-1\n",
    "    )\n",
    "    m.fit(X_tr_te, y_tr, eval_set=[(X_val_te, y_val)],\n",
    "          sample_weight=sw_tr,\n",
    "          callbacks=[lgb.early_stopping(50, verbose=False),\n",
    "                     lgb.log_evaluation(period=-1)])\n",
    "    oof[\"LGB\"][val_idx] = m.predict_proba(X_val_te)[:, 1]\n",
    "    test_p[\"LGB\"]      += m.predict_proba(X_test_te)[:, 1] / N_SPLITS\n",
    "    s = roc_auc_score(y_val, oof[\"LGB\"][val_idx])\n",
    "    fold_auc[\"LGB\"].append(s); print(f\"     LGB  AUC: {s:.4f}\")\n",
    "\n",
    "    # ── CatBoost ─────────────────────────────────────────────────────\n",
    "    m = CatBoostClassifier(\n",
    "        iterations=1000, learning_rate=0.05, depth=6,\n",
    "        l2_leaf_reg=3, bagging_temperature=0.5,\n",
    "        auto_class_weights=\"Balanced\" if USE_CLASS_WEIGHT else None,\n",
    "        eval_metric=\"AUC\", early_stopping_rounds=50,\n",
    "        random_seed=SEED, verbose=0\n",
    "    )\n",
    "    m.fit(X_tr_te, y_tr, eval_set=(X_val_te, y_val),\n",
    "          sample_weight=sw_tr)\n",
    "    oof[\"CAT\"][val_idx] = m.predict_proba(X_val_te)[:, 1]\n",
    "    test_p[\"CAT\"]      += m.predict_proba(X_test_te)[:, 1] / N_SPLITS\n",
    "    s = roc_auc_score(y_val, oof[\"CAT\"][val_idx])\n",
    "    fold_auc[\"CAT\"].append(s); print(f\"     CAT  AUC: {s:.4f}\")\n",
    "\n",
    "    # ── Random Forest ────────────────────────────────────────────────\n",
    "    m = RandomForestClassifier(\n",
    "        n_estimators=600, max_depth=14, min_samples_leaf=3,\n",
    "        max_features=\"sqrt\", max_samples=0.8,\n",
    "        class_weight=\"balanced\" if USE_CLASS_WEIGHT else None,\n",
    "        random_state=SEED, n_jobs=-1\n",
    "    )\n",
    "    m.fit(X_tr_le, y_tr, sample_weight=sw_tr)\n",
    "    oof[\"RF\"][val_idx] = m.predict_proba(X_val_le)[:, 1]\n",
    "    test_p[\"RF\"]      += m.predict_proba(X_test_le)[:, 1] / N_SPLITS\n",
    "    s = roc_auc_score(y_val, oof[\"RF\"][val_idx])\n",
    "    fold_auc[\"RF\"].append(s); print(f\"     RF   AUC: {s:.4f}\")\n",
    "\n",
    "    # ── ExtraTrees ───────────────────────────────────────────────────\n",
    "    m = ExtraTreesClassifier(\n",
    "        n_estimators=600, max_depth=14, min_samples_leaf=3,\n",
    "        max_features=\"sqrt\",\n",
    "        class_weight=\"balanced\" if USE_CLASS_WEIGHT else None,\n",
    "        random_state=SEED, n_jobs=-1\n",
    "    )\n",
    "    m.fit(X_tr_le, y_tr, sample_weight=sw_tr)\n",
    "    oof[\"ET\"][val_idx] = m.predict_proba(X_val_le)[:, 1]\n",
    "    test_p[\"ET\"]      += m.predict_proba(X_test_le)[:, 1] / N_SPLITS\n",
    "    s = roc_auc_score(y_val, oof[\"ET\"][val_idx])\n",
    "    fold_auc[\"ET\"].append(s); print(f\"     ET   AUC: {s:.4f}\")\n",
    "\n",
    "    # ── MLP — completely different function class ─────────────────────\n",
    "    scaler_mlp = StandardScaler()\n",
    "    X_tr_mlp   = scaler_mlp.fit_transform(X_tr_le)\n",
    "    X_val_mlp  = scaler_mlp.transform(X_val_le)\n",
    "    X_test_mlp = scaler_mlp.transform(X_test_le)\n",
    "\n",
    "    m = MLPClassifier(\n",
    "        hidden_layer_sizes=(256, 128, 64),\n",
    "        activation=\"relu\", solver=\"adam\",\n",
    "        alpha=0.001, batch_size=512,\n",
    "        learning_rate_init=0.001, max_iter=100,\n",
    "        early_stopping=True, validation_fraction=0.1,\n",
    "        random_state=SEED\n",
    "    )\n",
    "    m.fit(X_tr_mlp, y_tr)\n",
    "    oof[\"MLP\"][val_idx] = m.predict_proba(X_val_mlp)[:, 1]\n",
    "    test_p[\"MLP\"]      += m.predict_proba(X_test_mlp)[:, 1] / N_SPLITS\n",
    "    s = roc_auc_score(y_val, oof[\"MLP\"][val_idx])\n",
    "    fold_auc[\"MLP\"].append(s); print(f\"     MLP  AUC: {s:.4f}\")\n",
    "\n",
    "# Summary\n",
    "print(\"\\n  ── OOF Summary ──\")\n",
    "for m_name in models:\n",
    "    sc = fold_auc[m_name]\n",
    "    print(f\"  {m_name:5s}  mean={np.mean(sc):.4f}  std={np.std(sc):.4f}\")\n",
    "\n",
    "\n",
    "\n",
    "# SECTION 9 │ STACKING META-LEARNER\n",
    "\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"SECTION 9 │ Stacking Meta-Learner\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "oof_stack  = np.column_stack([oof[m]    for m in models])\n",
    "test_stack = np.column_stack([test_p[m] for m in models])\n",
    "\n",
    "scaler_meta = StandardScaler()\n",
    "oof_s       = scaler_meta.fit_transform(oof_stack)\n",
    "test_s      = scaler_meta.transform(test_stack)\n",
    "\n",
    "meta_lr_oof  = np.zeros(len(X_le)); meta_lr_test  = np.zeros(len(X_test_le))\n",
    "meta_rdg_oof = np.zeros(len(X_le)); meta_rdg_test = np.zeros(len(X_test_le))\n",
    "\n",
    "for tr_i, val_i in StratifiedKFold(n_splits=N_SPLITS, shuffle=True,\n",
    "                                     random_state=SEED).split(oof_s, y):\n",
    "    lr = LogisticRegression(C=0.5, max_iter=2000, random_state=SEED)\n",
    "    lr.fit(oof_s[tr_i], y.iloc[tr_i])\n",
    "    meta_lr_oof[val_i]  = lr.predict_proba(oof_s[val_i])[:, 1]\n",
    "    meta_lr_test       += lr.predict_proba(test_s)[:, 1] / N_SPLITS\n",
    "\n",
    "    rdg = Ridge(alpha=1.0)\n",
    "    rdg.fit(oof_s[tr_i], y.iloc[tr_i])\n",
    "    meta_rdg_oof[val_i] = rdg.predict(oof_s[val_i])\n",
    "    meta_rdg_test      += rdg.predict(test_s) / N_SPLITS\n",
    "\n",
    "meta_rdg_oof  = np.clip(meta_rdg_oof,  0, 1)\n",
    "meta_rdg_test = np.clip(meta_rdg_test, 0, 1)\n",
    "meta_oof  = 0.5*meta_lr_oof  + 0.5*meta_rdg_oof\n",
    "meta_test = 0.5*meta_lr_test + 0.5*meta_rdg_test\n",
    "\n",
    "print(f\"  LR  meta OOF AUC : {roc_auc_score(y, meta_lr_oof):.4f}\")\n",
    "print(f\"  RDG meta OOF AUC : {roc_auc_score(y, meta_rdg_oof):.4f}\")\n",
    "print(f\"  AVG meta OOF AUC : {roc_auc_score(y, meta_oof):.4f}\")\n",
    "\n",
    "\n",
    "# SECTION 10 │ FINAL BLEND\n",
    "\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"SECTION 10 │ Final Blend\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "base_aucs = {m: roc_auc_score(y, oof[m]) for m in models}\n",
    "total_auc = sum(base_aucs.values())\n",
    "weights   = {m: base_aucs[m] / total_auc for m in models}\n",
    "\n",
    "print(\"  Per-model OOF AUC & weight:\")\n",
    "for m in models:\n",
    "    print(f\"    {m:5s}  AUC={base_aucs[m]:.4f}  w={weights[m]:.3f}\")\n",
    "\n",
    "n  = len(X_le); nt = len(X_test_le)\n",
    "blend_oof  = sum(weights[m] * rankdata(oof[m])    / n  for m in models)\n",
    "blend_test = sum(weights[m] * rankdata(test_p[m]) / nt for m in models)\n",
    "\n",
    "auc_blend = roc_auc_score(y, blend_oof)\n",
    "print(f\"\\n  Weighted rank-blend OOF AUC : {auc_blend:.4f}\")\n",
    "\n",
    "final_oof  = 0.5*meta_oof  + 0.5*blend_oof\n",
    "final_test = 0.5*meta_test + 0.5*blend_test\n",
    "auc_final  = roc_auc_score(y, final_oof)\n",
    "print(f\"  FINAL combined OOF AUC     : {auc_final:.4f}\")\n",
    "\n",
    "\n",
    "# SECTION 11 │ SUBMISSION\n",
    "\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"SECTION 11 │ Submission\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "submission = pd.DataFrame({\"id\": test[\"id\"], \"Churn\": final_test})\n",
    "submission.to_csv(\"submission.csv\", index=False)\n",
    "\n",
    "print(f\"  Shape : {submission.shape}\")\n",
    "print(f\"  Mean  : {final_test.mean():.4f}  |  Std : {final_test.std():.4f}\")\n",
    "print(f\"  → submission.csv saved\")\n",
    "print(f\"\"\"\n",
    "\n",
    "Previous best   :  0.9161                           \n",
    "Stack OOF AUC   :  {roc_auc_score(y, meta_oof):.4f}                         \n",
    "Blend OOF AUC   :  {auc_blend:.4f}                         \n",
    "FINAL OOF AUC   :  {auc_final:.4f}                         \n",
    "\n",
    "\"\"\")"
   ]
